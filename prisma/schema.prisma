generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  // Primary Key
  id String @id @default(cuid())

  // User Information
  username String @unique
  email    String @unique
  fullName String

  // Profile Images (Cloudinary URLs)
  avatarUrl     String?
  coverImageUrl String?

  // Authentication
  isVerified Boolean @default(false)
  password     String
  refreshToken String?

  // Relations
  videos       Video[]
  comments     Comment[]
  tweets       Tweet[]
  videoLikes   VideoLike[]
  commentLikes CommentLike[]
  tweetLikes   TweetLike[]
  playlists    Playlist[]
  watchHistory WatchHistory[]

  subscriptions Subscription[] @relation("UserSubscriptions")

  subscribers Subscription[] @relation("UserSubscribers")
  // Timestamps
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Video {
  // Primary Key
  id String @id @default(cuid())

  // Video Information
  videoUrl     String
  thumbnailUrl String

  title       String
  description String?

  // Store duration in seconds
  duration Int

  // Statistics
  views       Int     @default(0)
  isPublished Boolean @default(false)

  // Foreign Key
  ownerId String

  // Relations
  owner        User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  comments     Comment[]
  likes        VideoLike[]
  playlists    PlaylistVideo[]
  watchHistory WatchHistory[]
  // Timestamps
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // Indexes
  @@index([ownerId, isPublished])
  @@index([ownerId])
  @@index([createdAt])
  @@index([isPublished])
}

model Comment {
  id String @id @default(cuid())

  content String

  ownerId String
  videoId String

  owner User  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  likes CommentLike[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([videoId])
  @@index([createdAt])
}

model Tweet {
  id String @id @default(cuid())

  content String

  ownerId String

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  likes TweetLike[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([createdAt])
}

model VideoLike {
  id String @id @default(cuid())

  userId  String
  videoId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, videoId])
  @@index([userId])
  @@index([videoId])
}

model CommentLike {
  id String @id @default(cuid())

  userId    String
  commentId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, commentId])
  @@index([userId])
  @@index([commentId])
}

model TweetLike {
  id String @id @default(cuid())

  userId  String
  tweetId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tweet Tweet @relation(fields: [tweetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, tweetId])
  @@index([userId])
  @@index([tweetId])
}

model Playlist {
  id String @id @default(cuid())

  name        String
  description String?

  createdById String

  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)

  videos PlaylistVideo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
}

model PlaylistVideo {
  id String @id @default(cuid())

  playlistId String
  videoId    String

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([playlistId, videoId])
  @@index([playlistId])
  @@index([videoId])
}

model Subscription {
  id String @id @default(cuid())

  subscriberId String
  channelId    String

  subscriber User @relation("UserSubscriptions", fields: [subscriberId], references: [id], onDelete: Cascade)

  channel User @relation("UserSubscribers", fields: [channelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([subscriberId, channelId])
  @@index([subscriberId])
  @@index([channelId])
}

model WatchHistory {
  id String @id @default(cuid())

  userId  String
  videoId String

  progressSeconds Int @default(0)

  completed Boolean @default(false)

  lastWatchedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([userId])
  @@index([videoId])
}
